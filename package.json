{
  "name": "auto-stitch-zoom-video-app",
  "private": true,
  "scripts": {
    "install:server": "npm --prefix server install",
    "install:client": "npm --prefix client install",
    "install:all": "npm run install:server && npm run install:client",
    "dev": "node ./scripts/dev.mjs",
    "start:prod": "node ./scripts/start-production.mjs",
    "share:local": "node ./scripts/start-production.mjs",
    "share:ngrok": "node ./scripts/share-with-tunnel.mjs ngrok",
    "tunnel:ngrok": "node ./scripts/tunnel.mjs ngrok",
    "tunnel:cloudflared": "node ./scripts/tunnel.mjs cloudflared",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "typecheck:server": "npm --prefix server run typecheck",
    "typecheck:client": "npm --prefix client run typecheck",
    "typecheck": "npm run typecheck:server && npm run typecheck:client",
    "lint:client": "npm --prefix client run lint",
    "build:server": "npm --prefix server run build",
    "build:client": "npm --prefix client run build",
    "build": "npm run build:server && npm run build:client",
    "test:client": "npm --prefix client run test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0"
  }
}
